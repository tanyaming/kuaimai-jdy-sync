# 快麦ERP TOKEN（从快麦开放平台获取）
KUAIMAI_APP_KEY=
KUAIMAI_APP_SECRET=
KUAIMAI_ACCESS_TOKEN=
KUAIMAI_REFRESH_TOKEN=

# 简道云 TOKEN（从简道云开放平台获取）
JIYUN_API_KEY=
JIYUN_API_SECRET=
JIYUN_BASE_URL=https://api.jiandaoyun.com

# 简道云 应用ID 和 表单ID
JIYUN_APP_ID=
JIYUN_ORDER_ENTRY_ID=
JIYUN_COST_ENTRY_ID=

# 同步间隔（分钟），默认 5 分钟
SYNC_INTERVAL_MINUTES=5

# 首次同步回溯天数
SYNC_LOOKBACK_DAYS=1

# 日志级别: trace | debug | info | warn | error
LOG_LEVEL=info
